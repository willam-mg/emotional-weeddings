{
    "name": "dipi/button-grid-child",
    "moduleIcon": "dipi/button-grid-child",
    "d4Shortcode": "dipi_button_grid_child",
    "title": "Pixel Button Grid Item",
    "titles": "Pixel Button Grid Items",
    "category": "child-module",
    "viewScript": "dipi-popup-gallery",
    "attributes": {
        "module": {
            "type": "object",
            "selector": "{{selector}}",
            "default": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Pixel Button Grid Item"
                        }
                    }
                },
                "advanced": {
                    "itemType": {
                        "desktop": {
                            "value": "Text"
                        }
                    },
                    "text": {
                        "text": {
                            "desktop": {
                                "value": {
                                    "orientation": "center"
                                }
                            }
                        }
                    }
                }
            },
            "styleProps": {
                "spacing": {
                    "important": true
                }
            }
        },
        "title": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                }
            }
        },
        "button_type": {
            "type": "object",
            "inlineEditor": "plainText",
            "childrenSanitizer": "et_core_esc_previously",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "button"
                    }
                }
            }
        },
        "button": {
            "type": "object",
            "selector": "{{selector}} .dipi-button-wrap.dipi-button-grid",
            "settings": {
                "innerContent": {},
                "decoration": {
                    "background": {},
                    "border": {},
                    "boxShadow": {},
                    "button": {},
                    "font": {},
                    "spacing": {}
                }
            },
            "attributes": {
                "class": "dipi-button-grid dipi-button-wrap"
            },
            "default": {
                "decoration": {
                    "button": {
                        "desktop": {
                            "value": {
                                "enable": "off",
                                "icon": {
                                    "enable": "on",
                                    "value": {}
                                }
                            }
                        }
                    },
                    "border": {
                        "desktop": {
                            "value": {
                                "styles": {
                                    "all": {
                                        "color": ""
                                    }
                                }
                            }
                        }
                    },
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {
                                    "color": ""
                                }
                            }
                        }
                    },
                    "spacing": {
                        "desktop": {
                            "value": {
                                "margin": {
                                    "top": "",
                                    "right": "",
                                    "left": "",
                                    "bottom": ""
                                },
                                "padding": {
                                    "top": "",
                                    "right": "",
                                    "left": "",
                                    "bottom": ""
                                }
                            }
                        }
                    }
                },
                "innerContent": {
                    "desktop": {
                        "value": {
                            "text": "Click Here",
                            "linkUrl": "#",
                            "linkTarget": "off"
                        }
                    }
                }
            },
            "elementType": "button",
            "elementProps": {
                "hasWrapper": false
            },
            "styleProps": {
                "selector": ".dipi_button_grid {{selector}} .dipi-button-wrap",
                "boxShadow": {
                    "propertySelectors": {
                        "desktop": {
                            "value": {
                                "box-shadow": "{{selector}} .dipi-button-wrap"
                            }
                        }
                    }
                },
                "button": {
                    "propertySelectors": {
                        "desktop": {
                            "value": {
                                "text-align": "{{selector}} .dipi-button-wrap"
                            }
                        }
                    }
                },
                "spacing": {
                    "propertySelectors": {
                        "desktop": {
                            "value": {
                                "margin": "{{selector}} .dipi-button-wrap",
                                "padding": "{{selector}} .dipi-button-wrap"
                            }
                        }
                    },
                    "important": {
                        "desktop": {
                            "value": {
                                "margin": true,
                                "padding": true
                            }
                        }
                    }
                },
                "font": {
                    "important": {
                        "font": {
                            "desktop": {
                                "value": {
                                    "color": true,
                                    "font-size": true,
                                    "letter-spacing": true
                                }
                            }
                        }
                    }
                }
            }
        },
        "text_style": {
            "type": "object",
            "selector": "{{selector}} .dipi-text-wrap",
            "tagName": "span",
            "inlineEditor": "plainText",
            "attributes": {
                "class": "dipi-text-wrap"
            },
            "childrenSanitizer": "et_core_esc_previously",
            "styleProps": {
                "font": {
                    "important": true
                }
            }
        },
        "text_info": {
            "type": "object",
            "inlineEditor": "plainText",
            "childrenSanitizer": "et_core_esc_previously",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                }
            }
        }
    },
    "customCssFields": {
        "button_type": {
            "subName": "button_type",
            "selectorSuffix": ".dipi-button-wrap"
        },
        "text_type": {
            "subName": "text_type",
            "selectorSuffix": ".dipi-text-wrap"
        }
    }
}