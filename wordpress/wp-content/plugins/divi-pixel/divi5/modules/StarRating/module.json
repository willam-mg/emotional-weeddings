{
    "name": "dipi/star-rating",
    "d4Shortcode": "dipi_star_rating",
    "title": "Pixel Star Rating",
    "titles": "Pixel Star Ratings",
    "moduleIcon": "dipi/star-rating",
    "category": "module",
    "attributes": {
        "module": {
            "type": "object",
            "selector": "{{selector}}",
            "default": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Pixel Star Rating"
                        }
                    }
                },
                "advanced": {
                    "text": {
                        "text": {
                            "desktop": {
                                "value": {
                                    "color": "light"
                                }
                            }
                        }
                    }
                }
            },
            "defaultPrintedStyle": {
                "decoration": {
                    "background": {
                        "desktop": {
                            "value": {
                                "color": "#ecf4f7"
                            }
                        }
                    }
                }
            },
            "styleProps": {
                "border": {
                    "important": true
                },
                "spacing": {
                    "important": true
                }
            }
        },
        "title": {
            "type": "object",
            "selector": "{{selector}} .dipi-title",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                },
                "decoration": {
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {
                                    "color": ""
                                }
                            }
                        }
                    }
                }
            }
        },
        "title_tag": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "h4"
                    }
                }
            }
        },
        "description": {
            "type": "object",
            "selector": "{{selector}} .dipi-description",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                },
                "decoration": {
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {
                                    "color": ""
                                }
                            }
                        }
                    }
                }
            }
        },
        "rating_scale": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "5"
                    }
                }
            }
        },
        "rating": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "3"
                    }
                }
            }
        },
        "display_type": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "block"
                    }
                }
            }
        },
        "show_rating_number": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "on"
                    }
                }
            }
        },
        "alignment": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "left"
                    }
                }
            }
        },
        "star_rating_icon_size": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "22px"
                    }
                }
            }
        },
        "star_rating_icon_spacing": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "0px"
                    }
                }
            }
        },
        "active_rating_icon_color": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "#f0ad4e"
                    }
                }
            }
        },
        "inactive_rating_icon_color": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "#f0ad4e"
                    }
                }
            }
        },
        "star_rating_number_color": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "#000000"
                    }
                }
            }
        },
        "star_rating_number_size": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "18px"
                    }
                }
            }
        }
    },
    "customCssFields": {
        "title": {
            "subName": "title",
            "selectorSuffix": " .dipi-wrapper .dipi-title"
        },
        "description": {
            "subName": "description",
            "selectorSuffix": " .dipi-wrapper .dipi-description"
        },
        "active_star": {
            "subName": "active_star",
            "selectorSuffix": " .dipi-wrapper .dipi-star-full"
        },
        "active_star_before": {
            "subName": "active_star_before",
            "selectorSuffix": " .dipi-wrapper .dipi-star-full:before"
        },
        "inactive_star": {
            "subName": "inactive_star",
            "selectorSuffix": " .dipi-wrapper .dipi-star-empty"
        },
        "rating_number": {
            "subName": "rating_number",
            "selectorSuffix": " .dipi-wrapper .dipi-star-rating-number"
        }
    }
}
