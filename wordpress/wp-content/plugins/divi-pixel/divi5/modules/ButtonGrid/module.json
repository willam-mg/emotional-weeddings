{
    "name": "dipi/button-grid",
    "moduleIcon": "dipi/button-grid",
    "d4Shortcode": "dipi_button_grid",
    "title": "Pixel Button Grid",
    "titles": "Pixel Button Grids",
    "childModuleName": "dipi/button-grid-child",
    "childModuleTitle": "Pixel Button Grid Item",
    "childrenName": [
        "dipi/button-grid-child"
    ],
    "category": "module",
    "attributes": {
        "module": {
            "type": "object",
            "selector": "{{selector}}",
            "default": {
                "meta": {
                    "adminLabel": {
                        "desktop": { "value": "Pixel Button Grid" }
                    }
                },
                "decoration": {
                    "itemSpacing": {
                        "desktop": {
                            "value": {
                                "desktop": "0px"
                            }
                        }
                    }
                },
                "advanced": {
                    "text": {
                        "text": {
                            "desktop": {
                                "value": {}
                            }
                        }
                    }
                },
                "styleProps": {
                    "border": {
                        "important": true
                    },
                    "spacing": {
                        "important": true
                    }
                }
            }
        },
        "flex_direction": {
            "type": "object",
            "inlineEditor": "plainText",
            "childrenSanitizer": "et_core_esc_previously",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "column"
                    }
                }
            }
        },
        "flex_wrap": {
            "type": "object",
            "inlineEditor": "plainText",
            "childrenSanitizer": "et_core_esc_previously",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "on"
                    }
                }
            }
        },
        "justify_content": {
            "type": "object",
            "inlineEditor": "plainText",
            "childrenSanitizer": "et_core_esc_previously",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "center"
                    }
                }
            }
        },
        "align_items": {
            "type": "object",
            "inlineEditor": "plainText",
            "childrenSanitizer": "et_core_esc_previously",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "baseline"
                    }
                }
            }
        },
        "text_style": {
            "type": "object",
            "selector": "{{selector}} .dipi-text-grid",
            "tagName": "span",
            "inlineEditor": "plainText",
            "attributes": {
                "class": "dipi-text-wrap"
            },
            "childrenSanitizer": "et_core_esc_previously",
            "default": {
                "decoration": {
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {
                                    "size": "16px",
                                    "lineHeight": "1em",
                                    "textAlign": "left"
                                }
                            }
                        }
                    }
                }
            }
        },
        "button_grid": {
            "type": "object",
            "selector": "{{selector}} .dipi-button-grid",
            "settings": {
                "innerContent": {},
                "decoration": {
                    "background": {},
                    "border": {},
                    "boxShadow": {},
                    "button": {},
                    "font": {},
                    "spacing": {}
                }
            },
            "attributes": {
                "class": "dipi-button-grid"
            },
            "default": {
                "decoration": {
                    "button": {
                        "desktop": {
                            "value": {
                                "enable": "off",
                                "icon": {
                                    "enable": "on"
                                }
                            }
                        }
                    },
                    "border": {
                        "desktop": {
                            "value": {
                                "styles": {
                                    "all": {
                                        "color": ""
                                    }
                                }
                            }
                        }
                    },
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {
                                    "color": ""
                                }
                            }
                        }
                    }
                }
            },
            "elementType": "button",
            "elementProps": {
                "hasWrapper": false,
                "allowEmptyUrl": true
            },
            "styleProps": {
                "font": {
                    "important": {
                        "font": {
                            "desktop": {
                                "value": {
                                    "color": true,
                                    "font-size": true,
                                    "letter-spacing": true
                                }
                            }
                        }
                    }
                },
                "spacing": {
                    "important": {
                        "desktop": {
                            "value": {
                                "margin": true,
                                "padding": true
                            }
                        }
                    }
                }
            }
        }
    },
    "customCssFields": {}
}
