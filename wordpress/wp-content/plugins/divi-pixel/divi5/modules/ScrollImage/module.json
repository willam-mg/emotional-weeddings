{
    "name": "dipi/scroll-image",
    "d4Shortcode": "dipi_scroll_image",
    "title": "Pixel Scroll Image",
    "titles": "Pixel Scroll Images",
    "moduleIcon": "dipi/scroll-image",
    "category": "module",
    "viewScript": "dipi_scroll_image_public",
    "attributes": {
        "module": {
            "type": "object",
            "selector": "{{selector}}",
            "default": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Pixel Scroll Image"
                        }
                    }
                },
                "advanced": {
                    "text": {
                        "text": {
                            "desktop": {
                                "value": {
                                    "color": "light"
                                }
                            }
                        }
                    }
                }
            },
            "defaultPrintedStyle": {
                "decoration": {
                    "background": {
                        "desktop": {
                            "value": {
                                "color": "#ecf4f7"
                            }
                        }
                    }
                }
            },
            "styleProps": {
                "spacing": {
                    "important": true
                }
            }
        },
        "direction_img": {
            "type": "object",
            "selector": "{{selector}} .dipi-image-scroll-content img",
            "default": {
                "decoration": {
                    "border": {
                        "desktop": {
                            "value": {
                                "styles": {
                                    "all": {
                                        "color": ""
                                    }
                                }
                            }
                        }
                    },
                    "boxShadow": {
                        "desktop": {
                            "value": {}
                        }
                    }
                }
            }
        },
        "scroll_image": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                }
            }
        },
        "img_alt": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                }
            }
        },
        "scroll_image_height": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "400px"
                    }
                }
            }
        },
        "use_overlay": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "overlay_direction": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "reveal_fade"
                    }
                }
            }
        },
        "scroll_type": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "on_hover"
                    }
                }
            }
        },
        "scroll_direction": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "vertical"
                    }
                }
            }
        },
        "reverse": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "scroll_speed": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "10"
                    }
                }
            }
        },
        "back_scroll_speed": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "5"
                    }
                }
            }
        },
        "use_direction_icon": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "use_image": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "direction_icon": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": {
                            "unicode": "4",
                            "type": "divi",
                            "weight": "400"
                        }
                    }
                }
            }
        },
        "direction_image": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                }
            }
        },
        "use_icon_animation": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "direction_image_width": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "70px"
                    }
                }
            }
        },
        "direction_img_alt": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                }
            }
        },
        "icon_color": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                }
            }
        },
        "use_icon_circle": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "icon_circle_color": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                }
            }
        },
        "use_icon_circle_border": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "icon_border_color": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                }
            }
        },
        "icon_size": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "50px"
                    }
                }
            }
        },
        "overlay_bg": {
            "type": "object",
            "selector": "{{selector}} .dipi-image-scroll-overlay",
            "default": {
                "decoration": {
                    "background": {
                        "desktop": {
                            "value": {
                                "color": "",
                                "image": {
                                    "size": "cover",
                                    "position": "center",
                                    "repeat": "no-repeat",
                                    "blend": "normal"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "customCssFields": {
        "image": {
            "subName": "image",
            "selectorSuffix": " .dipi-image-scroll-image img"
        },
        "image_container": {
            "subName": "image_container",
            "selectorSuffix": " .dipi-image-scroll-container"
        },
        "image_overlay": {
            "subName": "image_overlay",
            "selectorSuffix": " .dipi-image-scroll-overlay"
        },
        "icon": {
            "subName": "icon",
            "selectorSuffix": " .dipi-image-scroll-icon"
        },
        "icon_img": {
            "subName": "icon_img",
            "selectorSuffix": " .dipi-image-scroll-content img"
        }
    }
