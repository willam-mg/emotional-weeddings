{
  "name": "dipi/reveal",
  "d4Shortcode": "dipi_reveal",
  "title": "Pixel Reveal",
  "titles": "Pixel Reveals",
  "moduleIcon": "dipi/reveal",
  "category": "module",
  "viewScript": "dipi_reveal_public",
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "meta": {
          "adminLabel": {
            "desktop": {
              "value": "Pixel Reveal"
            }
          }
        }
      },
      "defaultPrintedStyle": {
        "decoration": {
          "background": {
            "desktop": {
              "value": {
                "color": "#ecf4f7"
              }
            }
          }
        }
      },
      "styleProps": {
        "border": {
          "important": true
        },
        "spacing": {
          "important": true
        }
      }
    },
    "container_selector": {
      "type": "object",
      "inlineEditor": "plainText",
      "childrenSanitizer": "et_core_esc_previously",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "default_show_status": {
      "type": "object",
      "inlineEditor": "plainText",
      "childrenSanitizer": "et_core_esc_previously",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "collapsed"
          }
        }
      }
    },
    "reveal_button_align": {
      "type": "object",
      "inlineEditor": "plainText",
      "childrenSanitizer": "et_core_esc_previously",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "center"
          }
        }
      }
    },

    "less_container_height": {
      "type": "object",
      "inlineEditor": "plainText",
      "childrenSanitizer": "et_core_esc_previously",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "100px"
          }
        }
      }
    },
    "less_v_offset": {
      "type": "object",
      "inlineEditor": "plainText",
      "childrenSanitizer": "et_core_esc_previously",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "0px"
          }
        }
      }
    },
    "less_animation_time": {
      "type": "object",
      "inlineEditor": "plainText",
      "childrenSanitizer": "et_core_esc_previously",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "800ms"
          }
        }
      }
    },
    "more_v_offset": {
      "type": "object",
      "inlineEditor": "plainText",
      "childrenSanitizer": "et_core_esc_previously",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "-100px"
          }
        }
      }
    },
    "more_animation_time": {
      "type": "object",
      "inlineEditor": "plainText",
      "childrenSanitizer": "et_core_esc_previously",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "800ms"
          }
        }
      }
    },
    "use_overlay": {
      "type": "object",
      "inlineEditor": "plainText",
      "childrenSanitizer": "et_core_esc_previously",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "overlay_as": {
      "type": "object",
      "inlineEditor": "plainText",
      "childrenSanitizer": "et_core_esc_previously",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "css"
          }
        }
      }
    },
    "append_to": {
      "type": "object",
      "inlineEditor": "plainText",
      "childrenSanitizer": "et_core_esc_previously",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "element"
          }
        }
      }
    },
    "overlay_z_index": {
      "type": "object",
      "inlineEditor": "plainText",
      "childrenSanitizer": "et_core_esc_previously",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "0"
          }
        }
      }
    },
    "overlay_bg": {
      "type": "object",
      "selector": "",
      "default": {
        "decoration": {
          "background": {
            "desktop": {
              "value": {
                "color": ""
              }
            }
          }
        }
      }
    },
    "show_less_button": {
      "type": "object",
      "selector": "{{selector}} .dipi-less-button.et_pb_button",
      "settings": {
        "innerContent": {},
        "decoration": {
          "background": {},
          "border": {},
          "boxShadow": {},
          "button": {},
          "font": {},
          "spacing": {}
        }
      },
      "attributes": {
        "class": "dipi-less-button dipi-reveal-button"
      },
      "default": {
        "decoration": {
          "button": {
            "desktop": {
              "value": {
                "icon": {
                  "enable": "on"
                }
              }
            }
          }
        },
        "innerContent": {
          "desktop": {
            "value": {
              "text": "Show Less",
              "linkUrl": "#none",
              "linkTarget": "off"
            }
          }
        }
      },
      "elementType": "button",
      "elementProps": {
        "hasWrapper": false
      },
      "styleProps": {
        "spacing": {
          "important": {
            "desktop": {
              "value": {
                "margin": true,
                "padding": true
              }
            }
          }
        },
        "border": {
          "important": true
        },
        "boxShadow": {
          "important": true
        }
      }
    },
    "show_more_button": {
      "type": "object",
      "selector": "{{selector}} .dipi-more-button.et_pb_button",
      "settings": {
        "innerContent": {},
        "decoration": {
          "background": {},
          "border": {},
          "boxShadow": {},
          "button": {},
          "font": {},
          "spacing": {}
        }
      },
      "attributes": {
        "class": "dipi-more-button dipi-reveal-button"
      },
      "default": {
        "decoration": {
          "button": {
            "desktop": {
              "value": {
                "icon": {
                  "enable": "on"
                }
              }
            }
          }
        },
        "innerContent": {
          "desktop": {
            "value": {
              "text": "Show More",
              "linkUrl": "#none",
              "linkTarget": "off"
            }
          }
        }
      },
      "elementType": "button",
      "elementProps": {
        "hasWrapper": false
      },
      "styleProps": {
        "spacing": {
          "important": {
            "desktop": {
              "value": {
                "margin": true,
                "padding": true
              }
            }
          }
        },
        "border": {
          "important": true
        },
        "boxShadow": {
          "important": true
        }
      }
    }
  },
  "customCssFields": {}
}
