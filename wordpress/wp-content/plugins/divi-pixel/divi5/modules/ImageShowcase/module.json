        "rotate": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "50"
                    }
                }
            }
        },
        "speed": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "500"
                    }
                }
            }
        },
        "loop": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "autoplay": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "pause_on_hover": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "on"
                    }
                }
            }
        },
        "autoplay_speed": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "5000"
                    }
                }
            }
        }
