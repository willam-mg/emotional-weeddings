  "moduleIcon": "dipi/typing-text",
  "category": "module",
  "viewScript": "dipi_typing_text_public",
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "meta": {
          "adminLabel": {
            "desktop": {
              "value": "Pixel Typing Text"
            }
          }
        },
        "advanced": {
