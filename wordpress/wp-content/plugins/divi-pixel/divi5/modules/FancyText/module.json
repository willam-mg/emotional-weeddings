{
  "name": "dipi/fancy-text",
  "d4Shortcode": "dipi_fancy_text",
  "title": "Pixel Fancy Text",
  "titles": "Pixel Fancy Texts",
  "moduleIcon": "dipi/fancy-text",
  "childModuleName": "dipi/fancy-text-child",
  "childModuleTitle": "Pixel Fancy Text Child",
  "childrenName": [
    "dipi/fancy-text-child"
  ],
  "category": "module",
  "viewScript": "dipi_fancy_text_public",
  "style": "dipi_animate",
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "meta": {
          "adminLabel": {
            "desktop": {
              "value": "Pixel Fancy Text"
            }
          }
        },
        "advanced": {
          "text": {
            "text": {
              "desktop": {
                "value": {
                  "color": "light"
                }
              }
            }
          }
        }
      },
      "defaultPrintedStyle": {
        "decoration": {
          "background": {
            "desktop": {
              "value": {
                "color": "#ecf4f7"
              }
            }
          }
        }
      },
      "styleProps": {
        "border": {
          "important": true
        },
        "spacing": {
          "important": true
        }
      }
    },
    "text_spacing": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": {
              "padding": {
                "top": "10px",
                "right": "10px",
                "bottom": "10px",
                "left": "10px"
              }
            }
          }
        }
      }
    },
    "prefix": {
      "type": "object",
      "inlineEditor": "plainText",
      "childrenSanitizer": "et_core_esc_previously",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "suffix": {
      "type": "object",
      "inlineEditor": "plainText",
      "childrenSanitizer": "et_core_esc_previously",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "sp_direction": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "horizontally"
          }
        }
      }
    },
    "in_animation": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "bounceIn"
          }
        }
      }
    },
    "out_animation": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "bounceOut"
          }
        }
      }
    },
    "highlight_animation_start": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "in_a_viewport"
          }
        }
      }
    },
    "highlight_animation_start_viewport": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "75%"
          }
        }
      }
    },
    "speed": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "2500"
          }
        }
      }
    },
    "duration": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "500"
          }
        }
      }
    },
    "animation_only_once": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      }
    },
    "all_font": {
      "type": "object",
      "selector": "{{selector}} .fancy-text",
      "default": {
        "decoration": {
          "font": {
            "font": {
              "desktop": {
                "value": {
                  "headingLevel": "h3",
                  "color": ""
                }
              }
            }
          }
        }
      }
    },
    "prefix_font": {
      "type": "object",
      "selector": "{{selector}} .fancy-text-prefix",
      "default": {
        "decoration": {
          "font": {
            "font": {
              "desktop": {
                "value": {
                  "color": ""
                }
              }
            }
          }
        }
      }
    },
    "text_font": {
      "type": "object",
      "selector": "{{selector}} .fancy-text-wrap",
      "default": {
        "decoration": {
          "font": {
            "font": {
              "desktop": {
                "value": {
                  "color": ""
                }
              }
            }
          }
        }
      }
    },
    "suffix_font": {
      "type": "object",
      "selector": "{{selector}} .fancy-text-suffix",
      "default": {
        "decoration": {
          "font": {
            "font": {
              "desktop": {
                "value": {
                  "color": ""
                }
              }
            }
          }
        }
      }
    }
  },
  "customCssFields": {}
}
