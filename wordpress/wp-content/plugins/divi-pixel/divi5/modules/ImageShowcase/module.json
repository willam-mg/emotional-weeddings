        "mockup_size": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "Large"
                    }
                }
            }
        },
        "enable_vertical_scroll": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "scroll_speed": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
