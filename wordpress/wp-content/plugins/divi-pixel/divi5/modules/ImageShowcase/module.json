{
    "name": "dipi/image-showcase",
    "d4Shortcode": "dipi_image_showcase",
    "title": "Pixel Image Showcase",
    "titles": "Pixel Image Showcase",
    "moduleIcon": "dipi/image-showcase",
    "childModuleName": "dipi/image-showcase-child",
    "childModuleTitle": "Pixel Image Showcase Item",
    "childrenName": [
        "dipi/image-showcase-child"
    ],
    "category": "module",
    "viewScript": "dipi_image_showcase_public_d5",
    "style": "dipi_swiper_d5",
    "attributes": {
        "module": {
            "type": "object",
            "selector": "{{selector}}",
            "default": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Pixel Image Showcase"
                        }
                    }
                },
                "advanced": {
                    "text": {
                        "text": {
                            "desktop": {
                                "value": {
                                    "color": "light"
                                }
                            }
                        }
                    }
                }
            },
            "defaultPrintedStyle": {
                "decoration": {
                    "background": {
                        "desktop": {
                            "value": {
                                "color": "#ecf4f7"
                            }
                        }
                    }
                }
            },
            "styleProps": {
                "border": {
                    "important": true
                },
                "spacing": {
                    "important": true
                }
            }
        },
        "mockup": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "iMac Front"
                    }
                }
