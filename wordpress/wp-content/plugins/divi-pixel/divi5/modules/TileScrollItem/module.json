{
    "name": "dipi/tile-scroll-item",
    "d4Shortcode": "dipi_tile_scroll_item",
    "title": "Pixel Tile Scroll Item",
    "titles": "Pixel Tile Scroll Items",
    "moduleIcon": "dipi/tile-scroll-item",
    "category": "child-module",
    "attributes": {
        "module": {
            "type": "object",
            "selector": ".dipi_tile_scroll {{selector}}",
            "default": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Pixel Tile Scroll Item"
                        }
                    }
                },
                "advanced": {
                    "text": {
                        "text": {
                            "desktop": {
                                "value": {
                                    "color": "light"
                                }
                            }
                        }
                    }
                }
            },
            "defaultPrintedStyle": {
                "decoration": {
                    "background": {
                        "desktop": {
                            "value": {
                                "color": "#ecf4f7"
                            }
                        }
                    }
                }
            },
            "styleProps": {
                "border": {
                    "important": true
                }
            }
        },
        "image": {
            "type": "object",
            "selector": "{{selector}}.dipi_tile_scroll_item .dipi-tile-scroll__line-img",
            "default": {
                "decoration": {
                    "border": {},
                    "boxShadow": {},
                    "sizing": {
                        "desktop": {
                            "value": {
                                "width": "200px",
                                "height": "200px"
                            }
                        }
                    }
                }
            }
        }
    },
    "customCssFields": {
        "image": {
            "subName": "image",
            "selectorSuffix": " .dipi-tile-scroll__line-img"
        }
    }
}