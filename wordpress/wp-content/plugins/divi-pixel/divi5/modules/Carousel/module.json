{
    "name": "dipi/carousel",
    "d4Shortcode": "dipi_carousel",
    "title": "Pixel Carousel",
    "titles": "Pixel Carousels",
    "moduleIcon": "dipi/carousel",
    "childModuleName": "dipi/carousel-child",
    "childModuleTitle": "Pixel Carousel Item",
    "childrenName": [
        "dipi/carousel-child"
    ],
    "category": "module",
    "style": ["dipi_animate", "magnific-popup"],
    "viewScript": ["dipi_carousel_public_d5", "dipi_swiper_d5"],
    "attributes": {
        "module": {
            "type": "object",
            "selector": "{{selector}}",
            "default": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Pixel Carousel"
                        }
                    }
                },
                "advanced": {
                    "text": {
                        "text": {
                            "desktop": {
                                "value": {
                                    "color": "light",
                                    "orientation": "center"
                                }
                            }
                        }
                    }
                }
            },
            "defaultPrintedStyle": {
                "decoration": {
                    "background": {
                        "desktop": {
                            "value": {
                                "color": "#ecf4f7"
                            }
                        }
                    }
                }
            },
            "styleProps": {
                "border": {
                    "important": true
                },
                "spacing": {
                    "important": true
                }
            }
        },
        "reverse_order": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "speed": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "500"
                    }
                }
            }
        },
        "loop": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "autoplay": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "continues": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "autoplay_speed": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "5000"
                    }
                }
            }
        },
        "container_padding": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": {
                            "padding": {
                                "top": "30px",
                                "right": "30px",
                                "bottom": "30px",
                                "left": "30px"
                            }
                        }
                    }
                }
            }
        },
        "show_lightbox": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "on"
                    }
                }
            }
        },
        "title_in_lightbox": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "desc_in_lightbox": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "allow_touch_move": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "on"
                    }
                }
            }
        },
        "use_thumbnail_height": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "thumbnail_height": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "400px"
                    }
                }
            }
        },
        "thumbnail_fit": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "cover"
                    }
                }
            }
        },
        "carousel_icon_align": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                }
            }
        },
        "title_font": {
            "type": "object",
            "selector": "{{selector}} .dipi_carousel_child .dipi-carousel-item-title",
            "default": {
                "decoration": {
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {
                                    "size": "22px",
                                    "lineHeight": "1em"
                                }
                            }
                        }
                    }
                }
            }
        },
        "desc_font": {
            "type": "object",
            "selector": "{{selector}} .dipi_carousel_child .dipi-carousel-item-desc",
            "default": {
                "decoration": {
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {
                                    "size": "15px",
                                    "lineHeight": "1em"
                                }
                            }
                        }
                    }
                }
            }
        },
        "button": {
            "type": "object",
            "selector": "{{selector}} .dipi-carousel-button",
            "settings": {
                "innerContent": {},
                "decoration": {
                    "background": {},
                    "border": {},
                    "boxShadow": {},
                    "button": {},
                    "font": {},
                    "spacing": {}
                }
            },
            "attributes": {
                "class": "dipi-carousel-button"
            },
            "default": {
                "decoration": {
                    "button": {
                        "desktop": {
                            "value": {
                                "enable": "off",
                                "icon": {
                                    "enable": "on",
                                    "value": {}
                                }
                            }
                        }
                    },
                    "border": {
                        "desktop": {
                            "value": {
                                "styles": {
                                    "all": {
                                        "color": ""
                                    }
                                }
                            }
                        }
                    },
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {
                                    "color": ""
                                }
                            }
                        }
                    }
                },
                "innerContent": {
                    "desktop": {
                        "value": {
                            "text": "Click Here",
                            "linkUrl": "#",
                            "linkTarget": "off"
                        }
                    }
                }
            },
            "elementType": "button",
            "elementProps": {
                "hasWrapper": false
            },
            "styleProps": {
                "selector": "{{selector}} .dipi-carousel-button",
                "boxShadow": {
                    "propertySelectors": {
                        "desktop": {
                            "value": {
                                "box-shadow": "{{selector}} .dipi-carousel-button"
                            }
                        }
                    }
                },
                "button": {
                    "propertySelectors": {
                        "desktop": {
                            "value": {
                                "text-align": "{{selector}} .dipi-carousel-button"
                            }
                        }
                    }
                },
                "spacing": {
                    "propertySelectors": {
                        "desktop": {
                            "value": {
                                "margin": "{{selector}} .dipi-carousel-button",
                                "padding": "{{selector}} .dipi-carousel-button"
                            }
                        }
                    },
                    "important": {
                        "desktop": {
                            "value": {
                                "margin": true,
                                "padding": true
                            }
                        }
                    }
                }
            }
        },
        "item": {
            "type": "object",
            "selector": "{{selector}} .dipi_carousel_child",
            "default": {
                "decoration": {
                    "border": {
                        "desktop": {
                            "value": {
                                "styles": {
                                    "all": {
                                        "color": ""
                                    }
                                }
                            }
                        }
                    },
                    "boxShadow": {
                        "desktop": {
                            "value": {}
                        }
                    }
                }
            }
        }
    },
    "customCssFields": {
        "img": {
            "subName": "img",
            "selectorSuffix": " .dipi-carousel-image"
        },
        "icon": {
            "subName": "icon",
            "selectorSuffix": " .dipi-carousel-icon"
        },
        "title": {
            "subName": "title",
            "selectorSuffix": " .dipi-carousel-item-title"
        },
        "description": {
            "subName": "description",
            "selectorSuffix": " .dipi-carousel-item-desc"
        },
        "button": {
            "subName": "button",
            "selectorSuffix": " .dipi-carousel-button"
        },
        "navigation": {
            "subName": "navigation",
            "selectorSuffix": " .swiper-arrow-button"
        },
        "prev_main_navigation": {
            "subName": "prev_main_navigation",
            "selectorSuffix": " .swiper-arrow-button.swiper-button-prev"
        },
        "next_thumbs_navigation": {
            "subName": "next_thumbs_navigation",
            "selectorSuffix": " .swiper-arrow-button.swiper-button-next"
        },
        "pagination": {
            "subName": "pagination",
            "selectorSuffix": " .swiper-pagination"
        },
        "active_slide": {
            "subName": "active_slide",
            "selectorSuffix": " .swiper-slide-active"
        },
        "not_active_slide": {
            "subName": "not_active_slide",
            "selectorSuffix": " .dipi_carousel_child:not(.swiper-slide-active)"
        }
    }
}
