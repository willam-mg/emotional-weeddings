{
    "name": "dipi/reading-progress-bar",
    "d4Shortcode": "dipi_reading_progress_bar",
    "title": "Pixel Reading Progress Bar",
    "titles": "Pixel Reading Progress Bars",
    "moduleIcon": "dipi/reading-progress-bar",
    "category": "module",
    "viewScript": "dipi_reading_progress_bar_public",
    "attributes": {
        "module": {
            "type": "object",
            "selector": "{{selector}}",
            "default": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Pixel Reading Progress Bar"
                        }
                    }
                },
                "advanced": {
                    "text": {
                        "text": {
                            "desktop": {
                                "value": {
                                    "color": "light"
                                }
                            }
                        }
                    }
                }
            },
            "defaultPrintedStyle": {
                "decoration": {
                    "background": {
                        "desktop": {
                            "value": {
                                "color": "#ecf4f7"
                            }
                        }
                    }
                }
            },
            "styleProps": {
                "border": {
                    "important": true
                }
            }
        },
        "bar_position": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "top"
                    }
                }
            }
        },
        "bar_animation": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "no"
                    }
                }
            }
        },
        "bar_bg_color": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "#fcfcfc"
                    }
                }
            }
        },
        "bar_color": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "#7cda24"
                    }
                }
            }
        },
        "bar_striped_color": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "#edf000"
                    }
                }
            }
        },
        "bar_size": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "5px"
                    }
                }
            }
        },
        "exclude_footer": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        }
    },
    "customCssFields": {}
}
