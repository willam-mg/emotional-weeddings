msgid "Reject All"
msgstr "すべて拒否"

#: cookieadmin/assets/cookie/policies.php:35
#: cookieadmin/assets/cookie/policies.php:70
msgid "Accept All"
msgstr "すべて承諾"

#: cookieadmin/assets/cookie/policies.php:38
