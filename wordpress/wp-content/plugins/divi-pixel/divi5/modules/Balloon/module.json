                        "desktop": {
                            "value": {
                                "margin": "{{selector}} .dipi-balloon-cta",
                                "padding": "{{selector}} .dipi-balloon-cta"
                            }
                        }
                    },
                    "important": {
                        "desktop": {
                            "value": {
                                "margin": true,
                                "padding": true
                            }
                        }
                    }
                }
            }
