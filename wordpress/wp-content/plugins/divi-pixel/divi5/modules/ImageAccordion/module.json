{
    "name": "dipi/image-accordion",
    "d4Shortcode": "dipi_image_accordion",
    "title": "Pixel Image Accordion",
    "titles": "Pixel Image Accordion",
    "moduleIcon": "dipi/image-accordion",
    "childModuleName": "dipi/image-accordion-child",
    "childModuleTitle": "Pixel Image Accordion Item",
    "childrenName": [
        "dipi/image-accordion-child"
    ],
    "category": "module",
    "viewScript": "dipi_image_accordion_public",
    "attributes": {
        "module": {
            "type": "object",
            "selector": "{{selector}}",
            "default": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Pixel Image Accordion"
                        }
                    }
                },
                "advanced": {
                    "text": {
                        "text": {
                            "desktop": {
                                "value": {
                                    "color": "light"
                                }
                            }
                        }
                    }
                }
            },
            "defaultPrintedStyle": {
                "decoration": {
                    "background": {
                        "desktop": {
                            "value": {
                                "color": "#ecf4f7"
                            }
                        }
                    }
                }
            },
            "styleProps": {
                "border": {
                    "important": true
                }
            }
        },
        "accordion_style": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "on_hover"
                    }
                }
            }
        },
        "accordion_direction": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "horizontal"
                    }
                }
            }
        },
        "accordion_height": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "400px"
                    }
                }
            }
        },
        "active_image_relative_width": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "5"
                    }
                }
            }
        },
        "always_visible": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "always_visible_fields": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": []
                    }
                }
            }
        }
    },
    "customCssFields": {
        "accordion_container": {
            "subName": "accordion_container",
            "selectorSuffix": " .dipi_image_accordion_wrapper"
        },
        "accordion_image_icon": {
            "subName": "accordion_image_icon",
            "selectorSuffix": " .dipi-accordion-image-icon"
        },
        "accordion_title": {
            "subName": "accordion_title",
            "selectorSuffix": " .dipi-accordion-title"
        },
        "accordion_description": {
            "subName": "accordion_description",
            "selectorSuffix": " .dipi-accordion-description"
        }
    }
}
