{
    "name": "dipi/text-highlighter",
    "d4Shortcode": "dipi_text_highlighter",
    "title": "Pixel Text Highlighter",
    "titles": "Pixel Text Highlighters",
    "moduleIcon": "dipi/text-highlighter",
    "category": "module",
    "viewScript": "dipi_text_highlighter_public",
    "attributes": {
        "module": {
            "type": "object",
            "selector": "{{selector}}",
            "default": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Pixel Text Highlighter"
                        }
                    }
                },
                "advanced": {
                    "text": {
                        "text": {
                            "desktop": {
                                "value": {
                                    "color": "light"
                                }
                            }
                        }
                    }
                }
            },
            "defaultPrintedStyle": {
                "decoration": {
                    "background": {
                        "desktop": {
                            "value": {
                                "color": "#ecf4f7"
                            }
                        }
                    }
                }
            },
            "styleProps": {
                "spacing": {
                    "important": true
                }
            }
        },
        "text_highlighter_prefix": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                }
            }
        },
        "text_highlighter_text": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                }
            }
        },
        "text_highlighter_suffix": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                }
            }
        },
        "highlight_shape": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "underline"
                    }
                }
            }
        },
        "text_wrapper_tag": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "h2"
                    }
                }
            }
        },
        "text_direction": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "inline"
                    }
                }
            }
        },
        "highlight_z_index": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "below"
                    }
                }
            }
        },
        "highlight_animation_start": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "in_a_viewport"
                    }
                }
            }
        },
        "highlight_animation_start_viewport": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "75%"
                    }
                }
            }
        },
        "highlight_animation_delay": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "0ms"
                    }
                }
            }
        },
        "highlight_animation_duration": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "800ms"
                    }
                }
            }
        },
        "highlight_delay_after_animation": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "3000ms"
                    }
                }
            }
        },
        "highlight_animation_repeat_mode": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "infinite"
                    }
                }
            }
        },
        "highlight_animation_count_mode": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "everytime_in_viewport"
                    }
                }
            }
        },
        "highlight_animation_repeat_counts": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "3"
                    }
                }
            }
        },
        "reverse_animation": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "stroke_color": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "#0077FF"
                    }
                }
            }
        },
        "stroke_width": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "9px"
                    }
                }
            }
        },
        "highlight_line_cap": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "round"
                    }
                }
            }
        },
        "shape_v_offset": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "0px"
                    }
                }
            }
        },
        "shape_h_offset": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "0px"
                    }
                }
            }
        },
        "shape_width_delta": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "20px"
                    }
                }
            }
        },
        "shape_height_delta": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "20px"
                    }
                }
            }
        },
        "highlighted_text_spacing": {
            "type": "object",
            "selector": "{{selector}} .dipi-text-highlight-wrapper",
            "default": {
                "decoration": {
                    "spacing": {
                        "desktop": {
                            "value": {
                                "margin": {
                                    "top": "",
                                    "bottom": "",
                                    "left": "",
                                    "right": ""
                                },
                                "padding": {
                                    "top": "",
                                    "bottom": "",
                                    "left": "",
                                    "right": ""
                                }
                            }
                        }
                    }
                }
            }
        },
        "all_text": {
            "type": "object",
            "selector": "{{selector}} .dipi-highlight-text-wrapper",
            "default": {
                "decoration": {
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {}
                            }
                        }
                    }
                }
            }
        },
        "prefix_text": {
            "type": "object",
            "selector": "{{selector}} .dipi-highlight-prefix-text",
            "default": {
                "decoration": {
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {}
                            }
                        }
                    }
                }
            }
        },
        "highlighted_text": {
            "type": "object",
            "selector": "{{selector}} .dipi-text-highlight-text",
            "default": {
                "decoration": {
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {}
                            }
                        }
                    }
                }
            }
        },
        "suffix_text": {
            "type": "object",
            "selector": "{{selector}} .dipi-highlight-suffix-text",
            "default": {
                "decoration": {
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {}
                            }
                        }
                    }
                }
            }
        }
    },
    "customCssFields": {
        "prefix": {
            "subName": "prefix",
            "selectorSuffix": " .dipi-highlight-text-wrapper .dipi-highlight-prefix-text"
        },
        "highlighted_text": {
            "subName": "highlighted_text",
            "selectorSuffix": " .dipi-highlight-text-wrapper .dipi-text-highlight-text"
        },
        "highlighted_shape": {
            "subName": "highlighted_shape",
            "selectorSuffix": " .dipi-text-highlight-wrapper svg"
        },
        "suffix": {
            "subName": "suffix",
            "selectorSuffix": " .dipi-highlight-text-wrapper .dipi-highlight-suffix-text"
        }
    }
}
