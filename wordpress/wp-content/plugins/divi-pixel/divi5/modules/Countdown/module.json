{
  "name": "dipi/countdown",
  "d4Shortcode": "dipi_countdown",
  "title": "Pixel Countdown",
  "titles": "Pixel Countdowns",
  "moduleIcon": "dipi/countdown",
  "category": "module",
  "viewScript": "dipi_countdown_public",
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "meta": {
          "adminLabel": {
            "desktop": {
              "value": "Pixel Countdown"
            }
          }
        },
        "advanced": {
          "text": {
            "text": {
              "desktop": {
                "value": {
                  "color": "light"
                }
              }
            }
          }
        }
      },
      "defaultPrintedStyle": {
        "decoration": {
          "background": {
            "desktop": {
              "value": {
                "color": "#ecf4f7"
              }
            }
          }
        }
      },
      "styleProps": {
        "border": {
          "important": true
        },
        "spacing": {
          "important": true
        }
      }
    },
    "date_type": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "picker"
          }
        }
      }
    },
    "date_time_picker": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "date_time_text": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "date_time_offset": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "use_cookie": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      }
    },
    "cookie_id": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "dipi_countdown"
          }
        }
      }
    },
    "finish_countdown": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "continue"
          }
        }
      }
    },
    "forwarding_url": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "script": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "html": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "style": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "flip_clock"
          }
        }
      }
    },
    "custom_format": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "%w %!w:Week,Weeks; %d %!d:Day,Days; %H %!H:Hour,Hours; %M %!M:Minute,Minutes; %S %!S:Second,Seconds;"
          }
        }
      }
    },
    "label_weeks": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "Week,Weeks"
          }
        }
      }
    },
    "label_days": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "Day,Days"
          }
        }
      }
    },
    "label_hours": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "Hour,Hours"
          }
        }
      }
    },
    "label_minutes": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "Min,Mins"
          }
        }
      }
    },
    "label_seconds": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "Sec,Secs"
          }
        }
      }
    },
    "clock_label_position": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "below"
          }
        }
      }
    },
    "show_weeks": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "show_days": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "show_hours": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "show_minutes": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "show_seconds": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "clock_background": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "#202020"
          }
        }
      }
    },
    "flip_clock_top_border": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "rgba(255, 255, 255, 0.2)"
          }
        }
      }
    },
    "flip_clock_separator_top_border": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "rgba(255, 255, 255, 0.1)"
          }
        }
      }
    },
    "flip_clock_separator_bottom_border": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "#000000"
          }
        }
      }
    },
    "flip_clock_bottom_border": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "#000000"
          }
        }
      }
    },
    "clock_face_width": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "clock_face_height": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "clock_face_margin": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {}
        }
      }
    },
    "clock_face_padding": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {}
        }
      }
    },
    "block_clock_equalize_width": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "block_clock_face_alignment": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "center"
          }
        }
      }
    },
    "clock_font": {
      "type": "object",
      "selector": "{{selector}} .flip_clock div.time span.count, {{selector}} .block_clock div.time",
      "default": {
        "decoration": {
          "font": {
            "desktop": {
              "value": {
                "color": ""
              }
            }
          }
        }
      }
    },
    "labels_font": {
      "type": "object",
      "selector": "{{selector}} .flip_clock div.label, {{selector}} .block_clock div.label",
      "default": {
        "decoration": {
          "font": {
            "desktop": {
              "value": {
                "color": ""
              }
            }
          }
        }
      }
    }
  },
  "customCssFields": {
    "dipi_countdown_flip_clock_count": {
      "subName": "dipi_countdown_flip_clock_count",
      "selectorSuffix": " .flip_clock .count"
    },
    "dipi_countdown_flip_clock_curr_top": {
      "subName": "dipi_countdown_flip_clock_curr_top",
      "selectorSuffix": " .flip_clock .count.curr.top"
    },
    "dipi_countdown_flip_clock_next_top": {
      "subName": "dipi_countdown_flip_clock_next_top",
      "selectorSuffix": " .flip_clock .count.next.top"
    },
    "dipi_countdown_flip_clock_curr_bot": {
      "subName": "dipi_countdown_flip_clock_curr_bot",
      "selectorSuffix": " .flip_clock .count.curr.bottom"
    },
    "dipi_countdown_flip_clock_next_bot": {
      "subName": "dipi_countdown_flip_clock_next_bot",
      "selectorSuffix": " .flip_clock .count.next.bottom"
    },
    "dipi_countdown_flip_clock_label": {
      "subName": "dipi_countdown_flip_clock_label",
      "selectorSuffix": " :is(.flip_clock .label,  .block_clock .label)"
    },
    "dipi_countdown_flip_clock_time": {
      "subName": "dipi_countdown_flip_clock_time",
      "selectorSuffix": " :is(.flip_clock .time, .block_clock .time)"
    },
    "dipi_countdown_flip_clock_weeks": {
      "subName": "dipi_countdown_flip_clock_weeks",
      "selectorSuffix": " :is(.flip_clock .time.weeks,  .block_clock .time.weeks)"
    },
    "dipi_countdown_flip_clock_days": {
      "subName": "dipi_countdown_flip_clock_days",
      "selectorSuffix": " :is(.flip_clock .time.days,  .block_clock .time.days)"
    },
    "dipi_countdown_flip_clock_hours": {
      "subName": "dipi_countdown_flip_clock_hours",
      "selectorSuffix": " :is(.flip_clock .time.hours,  .block_clock .time.hours)"
    },
    "dipi_countdown_flip_clock_mins": {
      "subName": "dipi_countdown_flip_clock_mins",
      "selectorSuffix": " :is(.flip_clock .time.minutes,  .block_clock .time.minutes)"
    },
    "dipi_countdown_flip_clock_secs": {
      "subName": "dipi_countdown_flip_clock_secs",
      "selectorSuffix": " :is(.flip_clock .time.seconds,  .block_clock .time.seconds)"
    },
    "dipi_countdown_flip_face_clock_weeks": {
      "subName": "dipi_countdown_flip_face_clock_weeks",
      "selectorSuffix": " :is(.flip_clock .face_weeks .count,  .block_clock .face_weeks)"
    },
    "dipi_countdown_flip_face_clock_days": {
      "subName": "dipi_countdown_flip_face_clock_days",
      "selectorSuffix": " :is(.flip_clock .face_days .count,  .block_clock .face_days)"
    },
    "dipi_countdown_flip_face_clock_hours": {
      "subName": "dipi_countdown_flip_face_clock_hours",
      "selectorSuffix": " :is(.flip_clock .face_hours .count,  .block_clock .face_hours)"
    },
    "dipi_countdown_flip_face_clock_mins": {
      "subName": "dipi_countdown_flip_face_clock_mins",
      "selectorSuffix": " :is(.flip_clock .face_minutes .count,  .block_clock .face_minutes)"
    },
    "dipi_countdown_flip_face_clock_secs": {
      "subName": "dipi_countdown_flip_face_clock_secs",
      "selectorSuffix": " :is(.flip_clock .face_seconds .count,  .block_clock .face_seconds)"
    }
  }
}
