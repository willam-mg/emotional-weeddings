{
    "name": "dipi/image-magnifier",
    "d4Shortcode": "dipi_image_magnifier",
    "title": "Pixel Image Magnifier",
    "titles": "Pixel Image Magnifiers",
    "moduleIcon": "dipi/image-magnifier",
    "category": "module",
    "viewScript": "dipi_image_magnifier_public",
    "style": "dipi_magnify",
    "attributes": {
        "module": {
            "type": "object",
            "selector": "{{selector}}",
            "default": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Pixel Image Magnifier"
                        }
                    }
                },
                "advanced": {
                    "text": {
                        "text": {
                            "desktop": {
                                "value": {
                                    "color": "light"
                                }
                            }
                        }
                    }
                }
            },
            "defaultPrintedStyle": {
                "decoration": {
                    "background": {
                        "desktop": {
                            "value": {
                                "color": "#ecf4f7"
                            }
                        }
                    }
                }
            },
            "styleProps": {
                "spacing": {
                    "important": true
                }
            }
        },
        "main_image": {
            "type": "object",
            "selector": "{{selector}} img",
            "elementType": "imageLink",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": {
                            "src": "",
                            "alt": ""
                        }
                    }
                },
                "decoration": {
                    "border": {
                        "desktop": {
                            "value": {
                                "styles": {
                                    "all": {
                                        "color": ""
                                    }
                                }
                            }
                        }
                    },
                    "boxShadow": {
                        "desktop": {
                            "value": {}
                        }
                    }
                }
            }
        },
        "img_alt": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": ""
                    }
                }
            }
        },
        "speed": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "300"
                    }
                }
            }
        },
        "lens_size": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "200"
                    }
                }
            }
        },
        "touch_bottom_offset": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "0"
                    }
                }
            }
        },
        "touch_lens_h_offset": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "0px"
                    }
                }
            }
        },
        "touch_lens_v_offset": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "0px"
                    }
                }
            }
        },
        "lens_border_size": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "7"
                    }
                }
            }
        },
        "lens_border_color": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "#fff"
                    }
                }
            }
        },
        "use_inset_shadow": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "off"
                    }
                }
            }
        },
        "inset_shadow_size": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "40"
                    }
                }
            }
        },
        "inset_shadow_color": {
            "type": "object",
            "default": {
                "innerContent": {
                    "desktop": {
                        "value": "#fff"
                    }
                }
            }
        }
    },
    "customCssFields": {
        "magnifier_img": {
            "subName": "magnifier_img",
            "selectorSuffix": " .dipi-image-magnifier img"
        }
    }
}
